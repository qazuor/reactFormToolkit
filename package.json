{
  "name": "@qazuor/react-form-toolkit",
  "version": "0.1.0",
  "description": "A strongly-typed React form toolkit built on top of React Hook Form",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "biome format --write .",
    "lint": "biome check .",
    "lint:fix": "biome check --apply .",
    "lint:ci": "biome ci .",
    "lint-staged": "biome check . --write --no-errors-on-unmatched --files-ignore-unknown=true",
    "prepare": "husky",
    "pack": "pnpm run build && npm pack",
    "publish": "pnpm run build && npm publish --access public"
  },
  "keywords": [
    "react",
    "form",
    "hook-form",
    "typescript",
    "zod"
  ],
  "author": "Your Name",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.1.0",
    "i18next": "^24.2.2",
    "react-hook-form": "^7.45.0",
    "react-i18next": "^15.4.1",
    "zod": "^3.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@hookform/resolvers": "^3.1.0",
    "@tailwindcss/vite": "^4.0.13",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^14.0.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^0.34.6",
    "happy-dom": "^12.10.3",
    "husky": "^9.1.7",
    "react": "^19",
    "react-dom": "^19",
    "react-hook-form": "^7.45.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.3",
    "vitest": "^0.34.6",
    "zod": "^3.21.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
